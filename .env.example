# Alpaca Markets API (required)
ALPACA_KEY_ID=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret

# Google Gemini API (required for AI analysis)
GEMINI_API_KEY=your_gemini_key

# Polygon.io (optional, for market regime detection)
POLYGON_API_KEY=your_polygon_key

# X.com / Twitter API (optional, for social sentiment)
X_BEARER_TOKEN=your_x_bearer_token

# PostgreSQL (agent memory + market data)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_memory
POSTGRES_USER=kronos
POSTGRES_PASSWORD=kronos_dev

# Cloudflare Tunnel (for cloud deployment)
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token
