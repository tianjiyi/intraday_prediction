    "token": "6QPWuIDQKqR6QqVmtO-Qf3ihazXPKdAfhv-OBwJB1eo",
    "idempotency_key": "tv-{{timenow}}-{{ticker}}-{{strategy.order.id}}",
    "source": "tradingview",
    "action": "{{strategy.market_position}}",
    "symbol": "{{ticker}}",
    "qty": "{{strategy.order.contracts}}",
    "order_type": "market",
